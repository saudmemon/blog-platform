# Server Configuration
PORT=5000

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/blog-platform
# For MongoDB Atlas, use:
# MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/blog-platform

# Environment
NODE_ENV=development

# File Upload
MAX_FILE_SIZE=5242880

# Optional: API Base URL (for CORS)
# API_URL=http://localhost:5000
